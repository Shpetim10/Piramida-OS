{
  "name": "piramida-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "planning:self-check": "tsx lib/planning/self-check.ts",
    "conflicts:self-check": "tsx lib/planning/conflict-self-check.ts",
    "conflicts:apply-self-check": "tsx lib/planning/apply-fix-self-check.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:check": "prisma validate && prisma migrate status",
