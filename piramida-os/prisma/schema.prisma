}

// Additive (2026-06-20): in-app/email notification ledger. Does not alter any
// locked decision; complements AuditLog (audit = what happened, notification =
// who we told). orgId is a plain column (no FK relation) matching the AuditLog
// pattern so we avoid touching Organization/Profile back-relations.
enum NotificationType {
  EVENT_REQUEST_RECEIVED
  EVENT_APPROVED
  EVENT_REJECTED
  CONFLICT_DETECTED
  PROPOSAL_SHARED
  PROPOSAL_RESPONDED
  TASK_ASSIGNED
  RESERVATION_UPDATED
  LAUNCH_READY
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
  DISMISSED
}

// ============================================================================
// ORGANIZATION & RBAC
// ============================================================================

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  timezone  String   @default("Europe/Tirane")
  currency  String   @default("ALL")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  profiles    Profile[]
  roles       Role[]
  clients     Client[]
  spaces      Space[]
  locations   Location[]
  appSettings AppSetting[]

  @@map("organizations")
}

model Profile {
  id           String        @id @default(uuid()) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  authUserId   String?       @unique @map("auth_user_id") @db.Uuid // -> auth.users.id (Supabase, other schema)
  type         ProfileType
  status       ProfileStatus @default(PENDING_APPROVAL)
  fullName     String        @map("full_name")
  displayName  String?       @map("display_name")
  email        String
  phone        String?
  title        String?
  avatarFileId String?       @map("avatar_file_id") @db.Uuid
  contactId    String?       @unique @map("contact_id") @db.Uuid // organizer link
  lastActiveAt DateTime?     @map("last_active_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)

  org          Organization  @relation(fields: [orgId], references: [id])
  contact      Contact?      @relation(fields: [contactId], references: [id])
  profileRoles ProfileRole[]

  @@unique([orgId, email])
  @@index([orgId, type])
  @@index([orgId, status])
  @@map("profiles")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  code        RoleCode
  label       String
  description String?
  permissions Json     @default("[]")
  isSystem    Boolean  @default(true) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  org          Organization  @relation(fields: [orgId], references: [id])
  profileRoles ProfileRole[]

  @@unique([orgId, code])
  @@map("roles")
}

model ProfileRole {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  profileId  String   @map("profile_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedBy String?  @map("assigned_by")
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([profileId, roleId])
  @@index([orgId])
  @@map("profile_roles")
}

// ============================================================================
// CLIENTS & CONTACTS
// ============================================================================

model Client {
  id           String    @id @default(uuid()) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  name         String
  legalName    String?   @map("legal_name")
  industry     String?
  website      String?
  billingEmail String?   @map("billing_email")
  taxId        String?   @map("tax_id")
  notes        String? // staff-only
  status       String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  org           Organization   @relation(fields: [orgId], references: [id])
  contacts      Contact[]
  eventRequests EventRequest[]
  events        Event[]
  quotes        Quote[]
  proposals     Proposal[]

  @@index([orgId])
  @@map("clients")
}

model Contact {
  id        String    @id @default(uuid()) @db.Uuid
  orgId     String    @map("org_id") @db.Uuid
  clientId  String    @map("client_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  email     String
  phone     String?
  roleTitle String?   @map("role_title")
  isPrimary Boolean   @default(false) @map("is_primary")
  status    String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  client           Client         @relation(fields: [clientId], references: [id])
  organizerProfile Profile?
  eventRequests    EventRequest[]
  proposals        Proposal[]

  @@index([orgId, clientId])
  @@map("contacts")
}

// ============================================================================
// EVENT REQUESTS & EVENTS
// ============================================================================

model EventRequest {
  id                   String              @id @default(uuid()) @db.Uuid
  orgId                String              @map("org_id") @db.Uuid
  clientId             String              @map("client_id") @db.Uuid
  contactId            String              @map("contact_id") @db.Uuid
  submittedByProfileId String?             @map("submitted_by_profile_id") @db.Uuid
  title                String?
  rawText              String              @map("raw_text")
  channel              String?
  status               EventRequestStatus  @default(RECEIVED)
  approvalStatus       EventApprovalStatus @default(PENDING_APPROVAL) @map("approval_status")
  extractedJson        Json?               @map("extracted_json")
  confidence           Float?
  missingFields        Json?               @map("missing_fields")
  reviewedById         String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt           DateTime?           @map("reviewed_at") @db.Timestamptz(6)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?           @map("deleted_at") @db.Timestamptz(6)

  client   Client                @relation(fields: [clientId], references: [id])
  contact  Contact               @relation(fields: [contactId], references: [id])
  event    Event?
  messages EventRequestMessage[]
  aiRuns   AiRun[]

  @@index([orgId, status])
  @@index([orgId, clientId])
  @@map("event_requests")
}

model EventRequestMessage {
  id              String   @id @default(uuid()) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  requestId       String   @map("request_id") @db.Uuid
  authorProfileId String?  @map("author_profile_id") @db.Uuid
  isFromOrganizer Boolean  @default(false) @map("is_from_organizer")
  body            String
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  request EventRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([orgId, requestId])
  @@map("event_request_messages")
}

model Event {
  id                   String              @id @default(uuid()) @db.Uuid
  orgId                String              @map("org_id") @db.Uuid
  requestId            String?             @unique @map("request_id") @db.Uuid
  clientId             String              @map("client_id") @db.Uuid
  code                 String
  title                String
  type                 EventType
  status               EventStatus         @default(PENDING_APPROVAL)
  approvalStatus       EventApprovalStatus @default(PENDING_APPROVAL) @map("approval_status")
  visibility           EventVisibility     @default(PRIVATE)
  expectedGuests       Int?                @map("expected_guests")
  eventStart           DateTime?           @map("event_start") @db.Timestamptz(6)
  eventEnd             DateTime?           @map("event_end") @db.Timestamptz(6)
  setupStart           DateTime?           @map("setup_start") @db.Timestamptz(6)
  teardownEnd          DateTime?           @map("teardown_end") @db.Timestamptz(6)
  returnBufferMinutes  Int?                @map("return_buffer_minutes")
  summary              String?
  currentPlanVersionId String?             @map("current_plan_version_id") @db.Uuid
  feasibilityScore     Float?              @map("feasibility_score")
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?           @map("deleted_at") @db.Timestamptz(6)

  client            Client             @relation(fields: [clientId], references: [id])
  request           EventRequest?      @relation(fields: [requestId], references: [id])
  requirements      EventRequirement[]
  planVersions      EventPlanVersion[]
  spaceReservations SpaceReservation[]
  assetReservations AssetReservation[]
  conflicts         Conflict[]
  tasks             Task[]
  quotes            Quote[]
  proposals         Proposal[]
  approvals         EventApproval[]
  publication       EventPublication?
  participants      EventParticipant[]

  @@unique([orgId, code])
  @@index([orgId, status])
  @@map("events")
}

model EventRequirement {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  key       String
  valueJson Json     @map("value_json")
  source    String? // ai | staff | derived
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([orgId, eventId])
  @@map("event_requirements")
}

model EventApproval {
  id                 String              @id @default(uuid()) @db.Uuid
  orgId              String              @map("org_id") @db.Uuid
  eventId            String?             @map("event_id") @db.Uuid
  eventRequestId     String?             @map("event_request_id") @db.Uuid
  status             EventApprovalStatus
  decidedByProfileId String?             @map("decided_by_profile_id") @db.Uuid
  decidedAt          DateTime?           @map("decided_at") @db.Timestamptz(6)
  reason             String?
  requestedChanges   Json?               @map("requested_changes")
  isAutomatedDraft   Boolean             @default(false) @map("is_automated_draft")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  event Event? @relation(fields: [eventId], references: [id])

  @@index([orgId, eventId])
  @@map("event_approvals")
}

// ============================================================================
// PLAN SNAPSHOTS & AI RUNS
// ============================================================================

model EventPlanVersion {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  version     Int
  snapshot    Json
  reason      String?
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  diffsFrom EventPlanDiff[] @relation("diff_from")
  diffsTo   EventPlanDiff[] @relation("diff_to")

  @@unique([eventId, version])
  @@index([orgId, eventId])
  @@map("event_plan_versions")
}

model EventPlanDiff {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  fromVersionId String   @map("from_version_id") @db.Uuid
  toVersionId   String   @map("to_version_id") @db.Uuid
  diff          Json
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  fromVersion EventPlanVersion @relation("diff_from", fields: [fromVersionId], references: [id], onDelete: Cascade)
  toVersion   EventPlanVersion @relation("diff_to", fields: [toVersionId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("event_plan_diffs")
}

model AiRun {
  id               String   @id @default(uuid()) @db.Uuid
  orgId            String   @map("org_id") @db.Uuid
  eventRequestId   String?  @map("event_request_id") @db.Uuid
  promptType       String   @map("prompt_type")
  model            String
  inputHash        String   @map("input_hash")
  latencyMs        Int?     @map("latency_ms")
  validationPassed Boolean  @default(false) @map("validation_passed")
  outputRef        Json?    @map("output_ref")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  eventRequest EventRequest? @relation(fields: [eventRequestId], references: [id])

  @@index([orgId, promptType])
  @@map("ai_runs")
}

// ============================================================================
// SPACES & LOCATIONS (3D-model ready; no LocationKey enum)
// ============================================================================

model Space {
  id               String    @id @default(uuid()) @db.Uuid
  orgId            String    @map("org_id") @db.Uuid
  name             String
  code             String?
  kind             SpaceKind
  capacity         Int?
  standingCapacity Int?      @map("standing_capacity")
  comfortFlow      Int?      @map("comfort_flow")
  floor            Int?
  publicVisible    Boolean   @default(false) @map("public_visible")
  staffOnly        Boolean   @default(true) @map("staff_only")
  modelNodeId      String?   @map("model_node_id")
  x                Float?
  y                Float?
  z                Float?
  width            Float?
  height           Float?
  depth            Float?
  sortOrder        Int?      @map("sort_order")
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  org             Organization       @relation(fields: [orgId], references: [id])
  locations       Location[]
  reservations    SpaceReservation[]
  adjacenciesFrom SpaceAdjacency[]   @relation("adj_from")
  adjacenciesTo   SpaceAdjacency[]   @relation("adj_to")
  tasks           Task[]
  agendaItems     AgendaItem[]

  @@unique([orgId, name])
  @@index([orgId, kind])
  @@map("spaces")
}

model SpaceAdjacency {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  fromSpaceId String   @map("from_space_id") @db.Uuid
  toSpaceId   String   @map("to_space_id") @db.Uuid
  travelLabel String?  @map("travel_label")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  fromSpace Space @relation("adj_from", fields: [fromSpaceId], references: [id], onDelete: Cascade)
  toSpace   Space @relation("adj_to", fields: [toSpaceId], references: [id], onDelete: Cascade)

  @@unique([fromSpaceId, toSpaceId])
  @@index([orgId])
  @@map("space_adjacencies")
}

model Location {
  id            String       @id @default(uuid()) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  spaceId       String?      @map("space_id") @db.Uuid
  name          String
  kind          LocationKind
  qrCode        String?      @map("qr_code")
  modelNodeId   String?      @map("model_node_id")
  floor         Int?
  x             Float?
  y             Float?
  z             Float?
  width         Float?
  height        Float?
  depth         Float?
  publicVisible Boolean      @default(false) @map("public_visible")
  staffOnly     Boolean      @default(true) @map("staff_only")
  sortOrder     Int?         @map("sort_order")
  metadata      Json         @default("{}")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)

  org           Organization    @relation(fields: [orgId], references: [id])
  space         Space?          @relation(fields: [spaceId], references: [id])
  homeAssets    Asset[]         @relation("asset_home")
  currentAssets Asset[]         @relation("asset_current")
  batches       AssetBatch[]
  movementsFrom AssetMovement[] @relation("move_from")
  movementsTo   AssetMovement[] @relation("move_to")
  tasks         Task[]

  @@unique([orgId, qrCode])
  @@index([orgId, kind])
  @@map("locations")
}

// ============================================================================
// ASSETS & INVENTORY
// Setup / teardown / return-buffer minutes are configurable per group
// (AssetCategory) with optional per-asset overrides (Asset, AssetBatch).
// ============================================================================

model AssetCategory {
  id                         String            @id @default(uuid()) @db.Uuid
  orgId                      String            @map("org_id") @db.Uuid
  name                       String
  code                       String?
  trackingMode               AssetTrackingMode @map("tracking_mode")
  unit                       String?
  defaultVisibility          AssetVisibility   @default(STAFF_ONLY) @map("default_visibility")
  // Group-level default reservation timing (minutes). Used unless an asset overrides.
  defaultSetupMinutes        Int               @default(0) @map("default_setup_minutes")
  defaultTeardownMinutes     Int               @default(0) @map("default_teardown_minutes")
  defaultReturnBufferMinutes Int               @default(30) @map("default_return_buffer_minutes")
  replacementCategoryId      String?           @map("replacement_category_id") @db.Uuid
  icon                       String?
  metadata                   Json              @default("{}")
  createdAt                  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                  DateTime?         @map("deleted_at") @db.Timestamptz(6)

  replacementCategory AssetCategory?         @relation("replacement", fields: [replacementCategoryId], references: [id])
  replacedBy          AssetCategory[]        @relation("replacement")
  assets              Asset[]
  batches             AssetBatch[]
  kitItems            AssetKitItem[]
  reservationItems    AssetReservationItem[]

  @@unique([orgId, name])
  @@index([orgId, trackingMode])
  @@map("asset_categories")
}

model Asset {
  id                  String          @id @default(uuid()) @db.Uuid
  orgId               String          @map("org_id") @db.Uuid
  categoryId          String          @map("category_id") @db.Uuid
  name                String
  assetTag            String          @map("asset_tag")
  qrCode              String?         @map("qr_code")
  serialNumber        String?         @map("serial_number")
  status              AssetStatus     @default(AVAILABLE)
  condition           AssetCondition  @default(GOOD)
  visibility          AssetVisibility @default(STAFF_ONLY)
  homeLocationId      String?         @map("home_location_id") @db.Uuid
  currentLocationId   String?         @map("current_location_id") @db.Uuid
  // Per-asset overrides for reservation timing (null => inherit category default)
  setupMinutes        Int?            @map("setup_minutes")
  teardownMinutes     Int?            @map("teardown_minutes")
  returnBufferMinutes Int?            @map("return_buffer_minutes")
  purchaseDate        DateTime?       @map("purchase_date") @db.Timestamptz(6)
  notes               String? // staff-only
  metadata            Json            @default("{}")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz(6)

  category         AssetCategory          @relation(fields: [categoryId], references: [id])
  homeLocation     Location?              @relation("asset_home", fields: [homeLocationId], references: [id])
  currentLocation  Location?              @relation("asset_current", fields: [currentLocationId], references: [id])
  kitItems         AssetKitItem[]
  reservationItems AssetReservationItem[]
  movements        AssetMovement[]
  issues           AssetIssue[]

  @@unique([orgId, assetTag])
  @@unique([orgId, qrCode])
  @@index([orgId, categoryId])
  @@index([orgId, status])
  @@map("assets")
}

model AssetBatch {
  id                  String          @id @default(uuid()) @db.Uuid
  orgId               String          @map("org_id") @db.Uuid
  categoryId          String          @map("category_id") @db.Uuid
  name                String
  homeLocationId      String?         @map("home_location_id") @db.Uuid
  totalQuantity       Int             @map("total_quantity")
  availableQuantity   Int             @map("available_quantity")
  reservedQuantity    Int             @default(0) @map("reserved_quantity")
  damagedQuantity     Int             @default(0) @map("damaged_quantity")
  unit                String?
  condition           AssetCondition  @default(GOOD)
  visibility          AssetVisibility @default(STAFF_ONLY)
  // Per-batch (group) overrides for reservation timing (null => inherit category default)
  setupMinutes        Int?            @map("setup_minutes")
  teardownMinutes     Int?            @map("teardown_minutes")
  returnBufferMinutes Int?            @map("return_buffer_minutes")
  metadata            Json            @default("{}")
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamptz(6)

  category         AssetCategory          @relation(fields: [categoryId], references: [id])
  homeLocation     Location?              @relation(fields: [homeLocationId], references: [id])
  kitItems         AssetKitItem[]
  reservationItems AssetReservationItem[]
  movements        AssetMovement[]
  issues           AssetIssue[]

  @@index([orgId, categoryId])
  @@map("asset_batches")
}

model AssetKit {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @map("org_id") @db.Uuid
  name        String
  code        String?
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  items AssetKitItem[]

  @@unique([orgId, name])
  @@map("asset_kits")
}

model AssetKitItem {
  id         String  @id @default(uuid()) @db.Uuid
  orgId      String  @map("org_id") @db.Uuid
  kitId      String  @map("kit_id") @db.Uuid
  categoryId String? @map("category_id") @db.Uuid
  assetId    String? @map("asset_id") @db.Uuid
  batchId    String? @map("batch_id") @db.Uuid
  quantity   Int     @default(1)
  isOptional Boolean @default(false) @map("is_optional")
  sortOrder  Int?    @map("sort_order")

  kit      AssetKit       @relation(fields: [kitId], references: [id], onDelete: Cascade)
  category AssetCategory? @relation(fields: [categoryId], references: [id])
  asset    Asset?         @relation(fields: [assetId], references: [id])
  batch    AssetBatch?    @relation(fields: [batchId], references: [id])

  @@index([orgId, kitId])
  @@map("asset_kit_items")
}

