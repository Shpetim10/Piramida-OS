model SpaceReservation {
  id          String                 @id @default(uuid()) @db.Uuid
  orgId       String                 @map("org_id") @db.Uuid
  eventId     String                 @map("event_id") @db.Uuid
  spaceId     String                 @map("space_id") @db.Uuid
  status      AssetReservationStatus @default(SOFT_HOLD)
  setupStart  DateTime               @map("setup_start") @db.Timestamptz(6)
  eventStart  DateTime               @map("event_start") @db.Timestamptz(6)
  eventEnd    DateTime               @map("event_end") @db.Timestamptz(6)
  teardownEnd DateTime               @map("teardown_end") @db.Timestamptz(6)
  notes       String?
  createdAt   DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?              @map("deleted_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id])

  @@index([orgId, eventId])
  @@index([spaceId, setupStart, teardownEnd])
  @@map("space_reservations")
}

model AssetReservation {
  id                  String                 @id @default(uuid()) @db.Uuid
  orgId               String                 @map("org_id") @db.Uuid
  eventId             String                 @map("event_id") @db.Uuid
  status              AssetReservationStatus @default(SOFT_HOLD)
  setupStart          DateTime               @map("setup_start") @db.Timestamptz(6)
  eventStart          DateTime               @map("event_start") @db.Timestamptz(6)
  eventEnd            DateTime               @map("event_end") @db.Timestamptz(6)
  teardownEnd         DateTime               @map("teardown_end") @db.Timestamptz(6)
  returnBufferMinutes Int                    @default(30) @map("return_buffer_minutes")
  notes               String?
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime?              @map("deleted_at") @db.Timestamptz(6)

  event Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items AssetReservationItem[]

  @@index([orgId, eventId])
  @@index([orgId, status])
  @@map("asset_reservations")
}

model AssetReservationItem {
  id             String                     @id @default(uuid()) @db.Uuid
  orgId          String                     @map("org_id") @db.Uuid
  reservationId  String                     @map("reservation_id") @db.Uuid
  categoryId     String?                    @map("category_id") @db.Uuid // category-level soft hold
  assetId        String?                    @map("asset_id") @db.Uuid // serialized
  batchId        String?                    @map("batch_id") @db.Uuid // bulk quantity
  quantity       Int                        @default(1)
  itemStatus     AssetReservationItemStatus @default(PENDING) @map("item_status")
  sourceKitId    String?                    @map("source_kit_id") @db.Uuid
  replacesItemId String?                    @unique @map("replaces_item_id") @db.Uuid
  // Effective window for this line, computed from the asset/category timing
  windowStart    DateTime?                  @map("window_start") @db.Timestamptz(6)
  windowEnd      DateTime?                  @map("window_end") @db.Timestamptz(6)
  createdAt      DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  reservation AssetReservation      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  category    AssetCategory?        @relation(fields: [categoryId], references: [id])
  asset       Asset?                @relation(fields: [assetId], references: [id])
  batch       AssetBatch?           @relation(fields: [batchId], references: [id])
  replaces    AssetReservationItem? @relation("substitution", fields: [replacesItemId], references: [id])
  replacedBy  AssetReservationItem? @relation("substitution")
  movements   AssetMovement[]

  @@index([orgId, reservationId])
  @@index([assetId, windowStart, windowEnd])
  @@map("asset_reservation_items")
}

model AssetMovement {
  id                 String              @id @default(uuid()) @db.Uuid
  orgId              String              @map("org_id") @db.Uuid
  assetId            String?             @map("asset_id") @db.Uuid
  batchId            String?             @map("batch_id") @db.Uuid
  reservationItemId  String?             @map("reservation_item_id") @db.Uuid
  quantity           Int?
  fromLocationId     String?             @map("from_location_id") @db.Uuid
  toLocationId       String?             @map("to_location_id") @db.Uuid
  status             AssetMovementStatus @default(PLANNED)
  scannedByProfileId String?             @map("scanned_by_profile_id") @db.Uuid
  scannedAt          DateTime            @default(now()) @map("scanned_at") @db.Timestamptz(6)
  notes              String?

  asset           Asset?                @relation(fields: [assetId], references: [id])
  batch           AssetBatch?           @relation(fields: [batchId], references: [id])
  reservationItem AssetReservationItem? @relation(fields: [reservationItemId], references: [id])
  fromLocation    Location?             @relation("move_from", fields: [fromLocationId], references: [id])
  toLocation      Location?             @relation("move_to", fields: [toLocationId], references: [id])

  @@index([orgId, assetId])
  @@map("asset_movements")
}

model AssetIssue {
  id                  String            @id @default(uuid()) @db.Uuid
  orgId               String            @map("org_id") @db.Uuid
  assetId             String?           @map("asset_id") @db.Uuid
