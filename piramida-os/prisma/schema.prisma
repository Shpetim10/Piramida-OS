  REJECT
  PUBLISH
  RESERVE
  RELEASE
  CONFLICT_DETECTED
  CONFLICT_RESOLVED
  AUTO_FIX_APPLIED
  PLAN_GENERATED
  CHECK_IN
  LAUNCH_OVERRIDE
