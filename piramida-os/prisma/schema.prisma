// Piramida / Pyramid OS — production data model
// Single organization (org_id everywhere), Supabase Postgres target.
// See docs/data-model-requirements.md for the full design rationale.
//
// Naming: models are PascalCase, tables snake_case plural (@@map),
// multi-word columns mapped to snake_case (@map) so hand-written SQL/RLS
// policies reference predictable column names.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS  (stable state/type values only — never locations)
// ============================================================================

enum ProfileStatus {
  ACTIVE
  INVITED
  PENDING_APPROVAL
  DISABLED
}

enum ProfileType {
  STAFF
  ORGANIZER
}

