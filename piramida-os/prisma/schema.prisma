}

model Attachment {
  id        String              @id @default(uuid()) @db.Uuid
  orgId     String              @map("org_id") @db.Uuid
  fileId    String              @map("file_id") @db.Uuid
  ownerType AttachmentOwnerType @map("owner_type")
  ownerId   String              @map("owner_id") @db.Uuid
  label     String?
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt DateTime?           @map("deleted_at") @db.Timestamptz(6)

  file FileObject @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([orgId, ownerType, ownerId])
  @@map("attachments")
}

model Comment {
  id              String            @id @default(uuid()) @db.Uuid
  orgId           String            @map("org_id") @db.Uuid
  ownerType       CommentOwnerType  @map("owner_type")
  ownerId         String            @map("owner_id") @db.Uuid
  authorProfileId String?           @map("author_profile_id") @db.Uuid
  visibility      CommentVisibility @default(INTERNAL)
  body            String
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  @@index([orgId, ownerType, ownerId])
  @@map("comments")
}

model AuditLog {
  id             String      @id @default(uuid()) @db.Uuid
  orgId          String      @map("org_id") @db.Uuid
  actorProfileId String?     @map("actor_profile_id") @db.Uuid
  action         AuditAction
  entityType     String      @map("entity_type")
  entityId       String      @map("entity_id") @db.Uuid
  summary        String?
  before         Json?
  after          Json?
  ip             String?
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, entityType, entityId])
  @@index([orgId, action])
  @@map("audit_logs")
}

model AppSetting {
  id          String           @id @default(uuid()) @db.Uuid
  orgId       String           @map("org_id") @db.Uuid
  key         String
  value       String
  valueType   SettingValueType @map("value_type")
  description String?
  group       String? // UI grouping bucket (e.g. "reservation", "storage", "billing")
  label       String? // human-friendly display label for an admin settings screen
  isSecret    Boolean          @default(false) @map("is_secret")
  isPublic    Boolean          @default(false) @map("is_public") // safe to expose to non-admin / client reads
  isEditable  Boolean          @default(true) @map("is_editable") // false => managed by code/migration only
  updatedById String?          @map("updated_by_id") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, key])
  @@map("app_settings")
}

// Additive (2026-06-20): normalized agenda rows. EventPublication.agenda (jsonb)
// is kept as a denormalized public cache; this table is the queryable,
// space-linked source of truth (doc Output 3 "agenda_items (optional)").
model AgendaItem {
  id            String   @id @default(uuid()) @db.Uuid
  orgId         String   @map("org_id") @db.Uuid
  publicationId String   @map("publication_id") @db.Uuid
  spaceId       String?  @map("space_id") @db.Uuid // optional link to a public Space
  title         String
  description   String?
  startsAt      DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt        DateTime @map("ends_at") @db.Timestamptz(6)
  sortOrder     Int?     @map("sort_order")
  publicVisible Boolean  @default(true) @map("public_visible")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  publication EventPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  space       Space?           @relation(fields: [spaceId], references: [id])

  @@index([orgId, publicationId])
  @@map("agenda_items")
}

model Notification {
  id                 String              @id @default(uuid()) @db.Uuid
  orgId              String              @map("org_id") @db.Uuid
  recipientProfileId String?             @map("recipient_profile_id") @db.Uuid // null => broadcast / system-wide
  type               NotificationType
  channel            NotificationChannel @default(IN_APP)
  status             NotificationStatus  @default(PENDING)
  title              String
  body               String?
  entityType         String?             @map("entity_type") // polymorphic source ref (no FK, AuditLog pattern)
  entityId           String?             @map("entity_id") @db.Uuid
  data               Json                @default("{}")
  readAt             DateTime?           @map("read_at") @db.Timestamptz(6)
  sentAt             DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([orgId, recipientProfileId, status])
  @@index([orgId, type])
  @@map("notifications")
}
